# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# === SECURITY ===
ALLOWED_USER_IDS=your_telegram_user_id

# === PATHS (defaults read from paths.json + more_paths.json — override here if needed) ===
# DB_PATH=./data/memory.db
# GOOGLE_CREDENTIALS_PATH=./tokens/google-oauth.json
# GOOGLE_TOKEN_PATH=./tokens/google-token.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./tokens/firebase.json

# === DATABASE ===
# Default if unset: see paths.json → files.database (usually data/memory.db)

# === LOCAL LLM (Ollama / vLLM — chat-completions HTTP API, not OpenAI Inc.) ===
# Prefer LOCAL_LLM_*; LOCAL_OPENAI_* still supported for backward compatibility.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_API_KEY=
# LOCAL_OPENAI_API_KEY=
# LOCAL_LLM_MODELS=llama3.2,mistral

# === ENGINE DEFAULTS ===
# DEFAULT_LLM_PROVIDER=        # leave empty for auto, or: local, gemini, groq
# DEFAULT_LLM_MODEL=

# === FIREBASE (optional - for cloud sync) ===
FIREBASE_PROJECT_ID=your_project_id
# Path below defaults to more_paths.json → firebase.serviceAccountJson
# FIREBASE_SERVICE_ACCOUNT_PATH=./tokens/firebase.json

# === AGENT ===
MAX_AGENT_ITERATIONS=15

# === MODELS (optional - defaults shown) ===
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# IMAGE_MODEL=gemini-3.1-flash-image-preview
# VIDEO_MODEL=veo-3.1-fast-generate-preview
# WHISPER_MODEL=whisper-large-v3-turbo

# === WEB UI ===
WEB_PORT=3000
WEB_HOST=localhost

# === GOOGLE OAUTH (optional - for Gmail/Calendar) ===
# Place OAuth client JSON at tokens/google-oauth.json (see more_paths.json)
# Optional second client: tokens/google-oauth-alt.json
