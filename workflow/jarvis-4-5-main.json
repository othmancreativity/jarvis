    {
      "parameters": {
        "jsCode": "const MAX_LEN = parseInt($env.TELEGRAM_MAX_MESSAGE_LENGTH || '4000', 10);\nlet text = String($json.responseText || '');\nif (text.length > MAX_LEN) {\n  const parts = [];\n  while (text.length > 0) {\n    let chunk = text.slice(0, MAX_LEN);\n    const lastBreak = Math.max(chunk.lastIndexOf('\\n'), chunk.lastIndexOf(' '));\n    if (lastBreak > MAX_LEN * 0.8) chunk = chunk.slice(0, lastBreak);\n    parts.push(chunk.trim());\n    text = text.slice(chunk.length);\n  }\n  return parts.map(p => ({ json: { ...$json, messageText: p } }));\n}\nreturn [{ json: { ...$json, messageText: text } }];"
      },
