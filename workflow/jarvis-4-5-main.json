    {
      "parameters": {
        "jsCode": "const userId = String($json.userId || 'default');\nconst limit = parseInt($env.RATE_LIMIT_PER_MINUTE || '30', 10);\nconst WINDOW_MS = 60_000;\nconst now = Date.now();\n\nconst sd = $getWorkflowStaticData('global');\nsd.rl = sd.rl || {};\nconst bucket = sd.rl[userId] || (sd.rl[userId] = []);\nwhile (bucket.length && (now - bucket[0]) > WINDOW_MS) bucket.shift();\n\nif (bucket.length >= limit) {\n  return [];\n}\n\nbucket.push(now);\nreturn [{ json: { ...$json, startTime: now } }];"
      },
