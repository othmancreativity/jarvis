{
  "registry_version": "4.0.0",
  "description": "Tool/Operation Registry for JARVIS 4.0 — Source of truth for all Google service operations",
  "services": {
    "youtube": {
      "description": "YouTube Data API v3",
      "base_url": "https://www.googleapis.com/youtube/v3",
      "operations": {
        "search": {
          "description": "Search for videos",
          "method": "GET",
          "endpoint": "/search",
          "required_params": ["q"],
          "optional_params": ["maxResults", "type", "order"],
          "risky": false
        },
        "get_video": {
          "description": "Get video details by ID",
          "method": "GET",
          "endpoint": "/videos",
          "required_params": ["id"],
          "optional_params": ["part"],
          "risky": false
        },
        "get_channel": {
          "description": "Get channel details by ID",
          "method": "GET",
          "endpoint": "/channels",
          "required_params": ["id"],
          "optional_params": ["part"],
          "risky": false
        },
        "list_playlists": {
          "description": "List playlists for a channel",
          "method": "GET",
          "endpoint": "/playlists",
          "required_params": ["channelId"],
          "optional_params": ["maxResults"],
          "risky": false
        }
      }
    },
    "drive": {
      "description": "Google Drive API v3",
      "base_url": "https://www.googleapis.com/drive/v3",
      "operations": {
        "list": {
          "description": "List files in Drive",
          "method": "GET",
          "endpoint": "/files",
          "required_params": [],
          "optional_params": ["pageSize", "q", "orderBy"],
          "risky": false
        },
        "get": {
          "description": "Get file metadata",
          "method": "GET",
          "endpoint": "/files/{fileId}",
          "required_params": ["fileId"],
          "optional_params": ["fields"],
          "risky": false
        },
        "create": {
          "description": "Create a new file/folder",
          "method": "POST",
          "endpoint": "/files",
          "required_params": ["name"],
          "optional_params": ["mimeType", "parents"],
          "risky": false
        },
        "update": {
          "description": "Update file metadata",
          "method": "PATCH",
          "endpoint": "/files/{fileId}",
          "required_params": ["fileId"],
          "optional_params": ["name", "mimeType"],
          "risky": false
        },
        "delete": {
          "description": "Delete a file (moves to trash)",
          "method": "DELETE",
          "endpoint": "/files/{fileId}",
          "required_params": ["fileId"],
          "optional_params": [],
          "risky": true
        },
        "upload": {
          "description": "Upload file content",
          "method": "POST",
          "endpoint": "/upload/drive/v3/files",
          "required_params": ["uploadType"],
          "optional_params": ["name"],
          "risky": false
        },
        "download": {
          "description": "Download file content",
          "method": "GET",
          "endpoint": "/files/{fileId}?alt=media",
          "required_params": ["fileId"],
          "optional_params": [],
          "risky": false
        }
      }
    },
